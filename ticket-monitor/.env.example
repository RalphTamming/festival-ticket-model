# Optional environment overrides. Copy to ".env" and edit.

# Scheduler
SCRAPE_INTERVAL_MINUTES=10

# Playwright
HEADLESS=false
SLOW_MO_MS=250
TIMEOUT_MS=60000

# Use installed Chrome if available (more normal user profile).
BROWSER_CHANNEL=chrome

# Recommended for trusted sessions: keep a persistent profile directory.
USE_PERSISTENT_CONTEXT=true
USER_DATA_DIR=./pw_user_data

USE_STORAGE_STATE=true
STORAGE_STATE_PATH=./playwright_state.json

SAVE_DEBUG_HTML=true
SAVE_DEBUG_SCREENSHOT=true

# SQLite
DATABASE_PATH=./data/ticket_monitor.sqlite3

